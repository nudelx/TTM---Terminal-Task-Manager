{
  "name": "ttm",
  "version": "0.0.1-b",
  "description": "Terminal task manager with a lazygit-style UI",
  "bin": {
    "ttm": "./bin/ttm.js"
  },
  "main": "src/App.js",
  "scripts": {
    "start": "node bin/ttm.js",
    "version:show": "node bin/ttm.js --version",
    "test": "node --test tests/*.test.js",
    "fix": "prettier --write .",
    "fix:check": "prettier --check ."
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "neo-blessed": "^0.2.0"
  },
  "license": "MIT",
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
